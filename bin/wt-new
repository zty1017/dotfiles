#!/usr/bin/env bash

set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
    echo "用法: wt-new <type> <name> [base_branch]" >&2
    echo "示例: wt-new feature new-loss main" >&2
    exit 1
fi

TYPE="$1"
NAME="$2"
BASE_BRANCH="${3:-main}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_dotfiles_lib.sh
source "$SCRIPT_DIR/_dotfiles_lib.sh"

require_git_repo

DOTFILES_DIR="${DOTFILES_DIR:-$(find_dotfiles_dir)}"
REPO_ROOT="$(git rev-parse --show-toplevel)"
REPO_BASENAME="$(basename "$REPO_ROOT")"

if [[ "$REPO_BASENAME" == *_workspace ]]; then
    WORKTREE_ROOT="$REPO_ROOT"
else
    WORKTREE_ROOT="$(cd "$REPO_ROOT/.." && pwd)"
fi

TYPE_SLUG="$(slugify "$TYPE")"
NAME_SLUG="$(slugify "$NAME")"
BRANCH_NAME="${TYPE_SLUG}-${NAME_SLUG}"
WORKTREE_NAME="wt-${BRANCH_NAME}"
WORKTREE_PATH="$WORKTREE_ROOT/$WORKTREE_NAME"

if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    echo "分支已存在: $BRANCH_NAME" >&2
    exit 1
fi

if [ -e "$WORKTREE_PATH" ]; then
    echo "目标目录已存在: $WORKTREE_PATH" >&2
    exit 1
fi

git -C "$REPO_ROOT" worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "$BASE_BRANCH"

cp "$DOTFILES_DIR/TASK_TEMPLATE.md" "$WORKTREE_PATH/TASK.md"

cat >> "$WORKTREE_PATH/TASK.md" <<EOF

## 自动初始化信息

- 分支：\`$BRANCH_NAME\`
- 基线分支：\`$BASE_BRANCH\`
- worktree：\`$WORKTREE_NAME\`
EOF

echo "已创建 worktree:"
echo "  分支: $BRANCH_NAME"
echo "  目录: $WORKTREE_PATH"
echo ""
echo "下一步建议:"
echo "  cd \"$WORKTREE_PATH\""
echo "  task-init    # 如需重新初始化或在其他目录使用"
echo "  task-handoff > HANDOFF.md"
